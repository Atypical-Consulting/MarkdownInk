---
import '@fontsource-variable/bricolage-grotesque/wght.css';
import '@fontsource-variable/hanken-grotesk/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';

interface Props { title: string; description?: string; active?: string }
const {
  title,
  description = 'MarkdownInk renders Markdown beautifully in your terminal — syntax-highlighted code, tables, lists, and footnotes. Use the mdink CLI, or plug the same engine into any AI agent over MCP.',
  active = '',
} = Astro.props;
const base = import.meta.env.BASE_URL; // ends with '/'
const nav = [
  { href: base, label: 'Overview', id: 'home' },
  { href: base + 'tools', label: 'Tools', id: 'tools' },
];
const repo = 'https://github.com/Atypical-Consulting/MarkdownInk';
const site = Astro.site ?? new URL('https://atypical-consulting.github.io');
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(base + 'og.png', site).href;

// Build-time GitHub star count for the "Star" button (authenticated in CI to dodge the rate
// limit; degrades to a plain Star link if the fetch fails).
let stars: number | null = null;
try {
  const token = process.env.GITHUB_TOKEN || process.env.GH_TOKEN;
  const res = await fetch('https://api.github.com/repos/Atypical-Consulting/MarkdownInk', {
    headers: {
      Accept: 'application/vnd.github+json',
      'User-Agent': 'MarkdownInk-docs-build',
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
    },
  });
  if (res.ok) stars = (await res.json()).stargazers_count ?? null;
} catch { /* leave stars null → plain Star link */ }
const starLabel =
  stars == null ? null : stars >= 1000 ? `${(stars / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(stars);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={base + 'favicon.svg'} type="image/svg+xml" />
    <meta name="theme-color" content="#f0b23e" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MarkdownInk" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="MarkdownInk — Markdown, rendered beautifully in your terminal. CLI + MCP." />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <style is:global>
      :root {
        --paper: #f4f1ea; --surface: #fbf9f4; --surface-2: #ece7dc; --inset: #f7f4ee;
        --ink: #1a1712; --ink-2: #4a443a; --muted: #8a8072; --line: #e4ddd0;
        --gold: #b47513; --gold-ink: #8f5c0e; --gold-soft: rgba(180,117,19,.10);
        --sap: #3f7d54; --sap-ink: #2f6340; --sap-soft: rgba(63,125,84,.10);
        --code-bg: #16130e; --code-fg: #ece7dc; --code-dim: #8a8072; --code-line: #2a251d;
        --shadow: 0 1px 2px rgba(26,23,18,.05), 0 8px 24px -12px rgba(26,23,18,.16);

        --display: 'Bricolage Grotesque Variable', var(--sans);
        --sans: 'Hanken Grotesk Variable', system-ui, -apple-system, sans-serif;
        --mono: 'JetBrains Mono Variable', ui-monospace, "SF Mono", Menlo, monospace;
        --maxw: 1120px; --r: 14px;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --paper: #100e0b; --surface: #17140f; --surface-2: #1e1a14; --inset: #130f09;
          --ink: #f3efe6; --ink-2: #bdb4a4; --muted: #837a6b; --line: #262019;
          --gold: #f0b23e; --gold-ink: #f6c260; --gold-soft: rgba(240,178,62,.15);
          --sap: #5fbf82; --sap-ink: #78d197; --sap-soft: rgba(95,191,130,.14);
          --code-bg: #0b0906; --code-fg: #ece7dc; --code-dim: #6d6555; --code-line: #221c14;
          --shadow: 0 1px 2px rgba(0,0,0,.34), 0 12px 30px -14px rgba(0,0,0,.6);
        }
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } * { animation-duration: .001ms !important; transition-duration: .001ms !important; } }
      body {
        margin: 0; background: var(--paper); color: var(--ink);
        font-family: var(--sans); font-size: 16.5px; line-height: 1.6; font-weight: 380;
        -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
      }
      a { color: var(--gold-ink); text-decoration: none; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }
      h1, h2, h3 { font-family: var(--display); font-weight: 620; line-height: 1.05; letter-spacing: -0.02em; color: var(--ink); }
      h1 { font-size: clamp(2.4rem, 6vw, 4rem); margin: 0; }
      h2 { font-size: clamp(1.6rem, 3.2vw, 2.3rem); margin: 0 0 .8rem; }
      h3 { font-size: 1.12rem; letter-spacing: -0.01em; margin: 0 0 .4rem; }
      p { color: var(--ink-2); }
      strong { color: var(--ink); font-weight: 600; }
      :focus-visible { outline: 2.5px solid var(--gold); outline-offset: 2px; border-radius: 4px; }

      .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 1.5rem; }
      .eyebrow { font-family: var(--mono); font-size: .74rem; font-weight: 500; letter-spacing: .14em;
        text-transform: uppercase; color: var(--muted); display: inline-flex; align-items: center; gap: .55rem; }
      .eyebrow::before { content: ""; width: 22px; height: 2px; background: var(--gold); display: inline-block; }
      .mono { font-family: var(--mono); }
      .lede { font-size: 1.2rem; line-height: 1.55; color: var(--ink-2); max-width: 60ch; }
      code { font-family: var(--mono); font-size: .86em; background: var(--surface-2); border: 1px solid var(--line);
        border-radius: 5px; padding: .08em .38em; color: var(--ink); }

      /* header */
      header.site { position: sticky; top: 0; z-index: 40; border-bottom: 1px solid var(--line);
        background: color-mix(in srgb, var(--paper) 82%, transparent); backdrop-filter: saturate(1.5) blur(10px); }
      header.site .bar { display: flex; align-items: center; gap: 1rem; height: 62px; }
      .brand { display: inline-flex; align-items: center; gap: .55rem; font-family: var(--display);
        font-weight: 640; font-size: 1.12rem; letter-spacing: -0.02em; color: var(--ink); }
      .brand:hover { text-decoration: none; }
      .brand .mark { width: 20px; height: 20px; display: inline-block; flex: none; }
      header.site nav { display: flex; align-items: center; gap: .15rem; margin-left: auto; }
      header.site nav a { color: var(--ink-2); font-size: .95rem; padding: .4rem .7rem; border-radius: 8px; }
      header.site nav a:hover { color: var(--ink); background: var(--surface-2); text-decoration: none; }
      header.site nav a[aria-current="page"] { color: var(--ink); }
      header.site nav a[aria-current="page"]::after { content: ""; display: block; height: 2px; margin-top: 3px; background: var(--gold); border-radius: 2px; }
      .nav-cta { margin-left: .5rem; }
      /* GitHub star button */
      .ghbtn { display: inline-flex; align-items: center; gap: .4rem; margin-left: .3rem; font-family: var(--sans);
        font-weight: 550; font-size: .9rem; color: var(--ink-2); padding: .34rem .6rem; border: 1px solid var(--line);
        border-radius: 8px; background: var(--surface); transition: border-color .12s ease, color .12s ease, transform .12s ease; }
      .ghbtn:hover { color: var(--ink); border-color: var(--muted); text-decoration: none; transform: translateY(-1px); }
      .ghbtn svg { color: #e3b341; flex: none; }
      .ghcount { font-family: var(--mono); font-size: .82rem; font-variant-numeric: tabular-nums; color: var(--ink);
        padding-left: .42rem; border-left: 1px solid var(--line); }
      @media (max-width: 620px) { header.site nav .hide-sm { display: none; } .ghbtn .ghlabel { display: none; } }

      /* buttons */
      .btn { display: inline-flex; align-items: center; gap: .5rem; font-family: var(--sans); font-weight: 560;
        font-size: .96rem; padding: .62rem 1.05rem; border-radius: 10px; border: 1px solid transparent; cursor: pointer; transition: transform .12s ease, box-shadow .12s ease, background .12s ease; }
      .btn:hover { text-decoration: none; transform: translateY(-1px); }
      .btn.primary { background: var(--gold); color: #1a1712; box-shadow: 0 6px 18px -6px var(--gold); }
      .btn.primary:hover { box-shadow: 0 10px 22px -8px var(--gold); }
      .btn.ghost { background: var(--surface); color: var(--ink); border-color: var(--line); box-shadow: var(--shadow); }
      .btn.ghost:hover { border-color: var(--muted); }

      /* pills */
      .pill { display: inline-flex; align-items: center; gap: .35rem; font-family: var(--mono); font-size: .72rem;
        font-weight: 500; letter-spacing: .02em; padding: .16rem .5rem; border-radius: 999px; border: 1px solid var(--line); color: var(--ink-2); background: var(--surface); }
      .pill.read { color: var(--sap-ink); border-color: color-mix(in srgb, var(--sap) 38%, var(--line)); background: var(--sap-soft); }
      .pill.write { color: var(--gold-ink); border-color: color-mix(in srgb, var(--gold) 38%, var(--line)); background: var(--gold-soft); }

      /* cards / surfaces */
      .card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r); padding: 1.25rem; box-shadow: var(--shadow); }
      section { padding: 3.6rem 0; }
      section + section { border-top: 1px solid var(--line); }
      .sec-head { margin-bottom: 1.8rem; }
      .sec-head p { margin: .4rem 0 0; max-width: 62ch; }

      /* code + copy */
      .codeblock { position: relative; background: var(--code-bg); border: 1px solid var(--code-line);
        border-radius: 12px; overflow: hidden; }
      .codeblock .cb-head { display: flex; align-items: center; gap: .5rem; padding: .5rem 3.6rem .5rem .85rem; border-bottom: 1px solid var(--code-line);
        font-family: var(--mono); font-size: .74rem; color: var(--code-dim); letter-spacing: .04em; }
      .codeblock pre { margin: 0; padding: .95rem 3.6rem .95rem 1.05rem; overflow-x: auto; font-family: var(--mono); font-size: .84rem; line-height: 1.65; color: var(--code-fg); }
      .codeblock pre code { background: none; border: none; padding: 0; color: inherit; font-size: inherit; }
      .tok-key { color: #6fb2ff; } .tok-str { color: #9ecb6b; } .tok-punc { color: var(--code-dim); }
      .tok-cmt { color: #6d6555; } .tok-fn { color: #f0b23e; } .tok-num { color: #e59b5c; }
      .copy { position: absolute; top: .5rem; right: .5rem; display: inline-flex; align-items: center; gap: .35rem;
        font-family: var(--mono); font-size: .72rem; color: var(--code-fg); background: rgba(255,255,255,.06);
        border: 1px solid var(--code-line); border-radius: 7px; padding: .28rem .5rem; cursor: pointer; }
      .copy:hover { background: rgba(255,255,255,.12); }
      .copy.done { color: #9ecb6b; border-color: #9ecb6b; }

      /* tables */
      .tablewrap { overflow-x: auto; border: 1px solid var(--line); border-radius: var(--r); background: var(--surface); box-shadow: var(--shadow); }
      table { border-collapse: collapse; width: 100%; font-size: .9rem; }
      th, td { text-align: left; padding: .62rem .85rem; border-bottom: 1px solid var(--line); white-space: nowrap; }
      thead th { color: var(--muted); font-weight: 600; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; font-family: var(--mono); }
      tbody tr:last-child td { border-bottom: none; }
      td.num, th.num { text-align: right; font-family: var(--mono); font-variant-numeric: tabular-nums; }
      td.tmono { font-family: var(--mono); }

      .note { border: 1px solid var(--line); border-left: 3px solid var(--gold); background: var(--surface);
        border-radius: 12px; padding: 1.05rem 1.2rem; box-shadow: var(--shadow); }
      .note h3 { margin-top: 0; }
      .note :last-child { margin-bottom: 0; }
      .muted { color: var(--muted); }
      .small { font-size: .84rem; }
      ul.clean { padding-left: 1.15rem; } ul.clean li { margin: .4rem 0; color: var(--ink-2); }

      footer.site { border-top: 1px solid var(--line); padding: 2.4rem 0; color: var(--muted); font-size: .9rem; background: var(--surface); }
      footer.site .frow { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; justify-content: space-between; }
      footer.site a { color: var(--ink-2); }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap bar">
        <a class="brand" href={base}>
          <svg class="mark" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
            <rect width="32" height="32" rx="8" fill="#141210"></rect>
            <path d="M16 5c4 7 7 10 7 14a7 7 0 1 1-14 0c0-4 3-7 7-14Z" fill="#f0b23e"></path>
          </svg>
          MarkdownInk
        </a>
        <nav>
          {nav.map((n) => <a href={n.href} class="hide-sm" aria-current={active === n.id ? 'page' : undefined}>{n.label}</a>)}
          <a class="ghbtn" href={repo} target="_blank" rel="noopener noreferrer"
             aria-label={stars == null ? 'Star MarkdownInk on GitHub' : `Star MarkdownInk on GitHub — ${stars} stars`}>
            <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true" focusable="false"><path fill="currentColor" d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.767 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
            <span class="ghlabel">Star</span>
            <span class="ghcount" id="gh-star-count" hidden={!starLabel}>{starLabel}</span>
          </a>
          <a class="btn ghost nav-cta" href={active === 'home' ? '#install' : base + '#install'}>Install</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site"><div class="wrap frow">
      <span>MarkdownInk — Markdown, rendered beautifully in your terminal.</span>
      <span><a href={repo}>GitHub</a> · <a href={base + 'tools'}>MCP tools</a> · MIT © Atypical Consulting</span>
    </div></footer>

    <script>
      // Refresh the top-bar star count client-side so it's current, not just the build-time
      // snapshot. Unauthenticated (60/hr per IP) — on rate-limit or error we keep the built-in value.
      (async () => {
        const el = document.getElementById('gh-star-count');
        if (!el) return;
        try {
          const res = await fetch('https://api.github.com/repos/Atypical-Consulting/MarkdownInk', {
            headers: { Accept: 'application/vnd.github+json' },
          });
          if (!res.ok) return;
          const n = (await res.json()).stargazers_count;
          if (typeof n !== 'number') return;
          el.textContent = n >= 1000 ? `${(n / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(n);
          el.hidden = false;
        } catch { /* keep the build-time value */ }
      })();

      document.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('.copy');
        if (!btn) return;
        const sel = btn.getAttribute('data-copy-target');
        const src = sel ? document.querySelector(sel) : btn.closest('.codeblock')?.querySelector('pre');
        const text = src?.textContent ?? '';
        navigator.clipboard.writeText(text.trim()).then(() => {
          const label = btn.querySelector('.copy-label');
          const prev = label ? label.textContent : '';
          if (label) label.textContent = 'Copied';
          btn.classList.add('done');
          setTimeout(() => { if (label) label.textContent = prev; btn.classList.remove('done'); }, 1600);
        });
      });

      // Install-method tabs (progressive enhancement over stacked panels)
      document.querySelectorAll('[data-install-tabs]').forEach((group) => {
        const tabs = Array.from(group.querySelectorAll('[role="tab"]')) as HTMLElement[];
        const activate = (tab: HTMLElement, focus: boolean) => {
          tabs.forEach((t) => {
            const on = t === tab;
            t.setAttribute('aria-selected', String(on));
            t.tabIndex = on ? 0 : -1;
            const panel = document.getElementById(t.getAttribute('aria-controls') || '');
            if (panel) (panel as HTMLElement).hidden = !on;
          });
          if (focus) tab.focus();
        };
        tabs.forEach((t) => { t.tabIndex = t.getAttribute('aria-selected') === 'true' ? 0 : -1; });
        const list = group.querySelector('[role="tablist"]');
        list?.addEventListener('click', (e) => {
          const tab = (e.target as HTMLElement).closest('[role="tab"]') as HTMLElement | null;
          if (tab) activate(tab, false);
        });
        list?.addEventListener('keydown', (e) => {
          const ev = e as KeyboardEvent;
          const i = tabs.indexOf(document.activeElement as HTMLElement);
          if (i < 0) return;
          if (ev.key === 'ArrowRight' || ev.key === 'ArrowDown') { ev.preventDefault(); activate(tabs[(i + 1) % tabs.length], true); }
          else if (ev.key === 'ArrowLeft' || ev.key === 'ArrowUp') { ev.preventDefault(); activate(tabs[(i - 1 + tabs.length) % tabs.length], true); }
          else if (ev.key === 'Home') { ev.preventDefault(); activate(tabs[0], true); }
          else if (ev.key === 'End') { ev.preventDefault(); activate(tabs[tabs.length - 1], true); }
        });
      });
    </script>
  </body>
</html>
